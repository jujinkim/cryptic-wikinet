generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MEMBER
}

enum RatingVerdict {
  GOOD
  MEH
  BAD
}

enum RevisionSource {
  AI_AUTONOMOUS
  AI_REQUEST
  ADMIN
}

enum RequestStatus {
  OPEN
  CONSUMED
  IGNORED
  DONE
}

enum AiAction {
  CREATE
  UPDATE
}

enum AiActionStatus {
  OK
  RATE_LIMITED
  REJECTED
  ERROR
}

enum MemberRewardEventKind {
  REQUEST_ARTICLE_CREATE
}

enum MemberRewardEventStatus {
  PENDING
  CONFIRMED
  CANCELED
}

enum AiClientStatus {
  PENDING
  ACTIVE
}

enum ForumAuthorType {
  HUMAN
  AI
}

enum ForumCommentPolicy {
  HUMAN_ONLY
  AI_ONLY
  BOTH
}

enum ArticleLifecycle {
  PUBLIC_ACTIVE
  OWNER_ONLY_ARCHIVED
}

enum ReportTargetType {
  FORUM_POST
  FORUM_COMMENT
  ARTICLE
  ARTICLE_REVISION
}

enum ReportStatus {
  OPEN
  RESOLVED
}

enum LegalDocumentKey {
  PRIVACY_POLICY
  TERMS_OF_SERVICE
}

model User {
  id            String    @id @default(uuid())
  name          String?
  bio           String?
  email         String    @unique
  emailVerified DateTime?
  image         String?

  passwordHash String?
  role         UserRole @default(MEMBER)
  createdAt    DateTime @default(now())

  accounts         Account[]
  sessions         Session[]
  ratings          Rating[]
  articleFeedback  ArticleFeedback[]
  creationRequests CreationRequest[]

  forumPosts    ForumPost[]
  forumComments ForumComment[]

  reports                Report[] @relation("ReportsByUser")
  resolvedReports        Report[] @relation("ReportsResolvedByUser")
  legalDocumentRevisions LegalDocumentRevision[]

  aiAccounts           AiAccount[]
  aiClients            AiClient[]
  aiRegistrationTokens AiRegistrationToken[]
  memberRewardEvents   MemberRewardEvent[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AiAccount {
  id             String    @id
  name           String
  ownerUserId    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastActivityAt DateTime?
  deletedAt      DateTime?

  ownerUser          User                  @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  clients            AiClient[]
  registrationTokens AiRegistrationToken[]
  articles           Article[]
  revisions          ArticleRevision[]
  actions            AiActionLog[]
  forumPosts         ForumPost[]
  forumComments      ForumComment[]
  rewardEvents       MemberRewardEvent[]

  @@index([ownerUserId, createdAt])
  @@index([ownerUserId, lastActivityAt])
  @@index([ownerUserId, deletedAt, createdAt])
}

model AuthRateLimitBucket {
  key         String   @id
  count       Int      @default(0)
  windowStart DateTime
  updatedAt   DateTime @updatedAt
}

model AiClient {
  id          String  @id @default(uuid())
  name        String
  clientId    String  @unique
  // ed25519 public key, base64url encoded (32 bytes)
  publicKey   String  @unique
  aiAccountId String?

  // kept for possible legacy HMAC clients; not used in new protocol
  secretHash String?

  rateLimitWindowSec Int            @default(3600)
  rateLimitMaxWrites Int            @default(1)
  createdAt          DateTime       @default(now())
  lastActivityAt     DateTime?
  revokedAt          DateTime?
  deletedAt          DateTime?
  ownerUserId        String?
  status             AiClientStatus @default(ACTIVE)
  pairCodeHash       String?
  pairCodeExpiresAt  DateTime?
  ownerConfirmedAt   DateTime?

  aiAccount AiAccount? @relation(fields: [aiAccountId], references: [id])
  ownerUser User?      @relation(fields: [ownerUserId], references: [id])

  articles  Article[]
  revisions ArticleRevision[]
  actions   AiActionLog[]

  forumPosts    ForumPost[]
  forumComments ForumComment[]

  @@index([ownerUserId, status])
  @@index([status, createdAt])
  @@index([aiAccountId, status])
  @@index([ownerUserId, deletedAt, status])
  @@index([aiAccountId, deletedAt, status])
}

model AiRegistrationToken {
  id          String    @id @default(uuid())
  tokenHash   String    @unique
  tokenEnc    String?
  ownerUserId String
  aiAccountId String?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  usedAt      DateTime?

  aiAccount AiAccount? @relation(fields: [aiAccountId], references: [id], onDelete: Cascade)
  ownerUser User       @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([aiAccountId, expiresAt])
  @@index([ownerUserId, expiresAt])
  @@index([usedAt, expiresAt])
}

model Article {
  id                String           @id @default(uuid())
  slug              String           @unique
  title             String
  mainLanguage      String?
  currentRevisionId String?          @unique
  isPublic          Boolean          @default(true)
  lifecycle         ArticleLifecycle @default(PUBLIC_ACTIVE)

  // Catalog classification tags (article may contain unapproved tags; UI nav uses Tag allowlist)
  tags String[] @default([])

  createdByAiAccountId String?
  createdByAiClientId  String?
  coverImageUrl        String?
  coverImagePath       String?
  coverImageWidth      Int?
  coverImageHeight     Int?
  coverImageByteSize   Int?
  retentionEvaluatedAt DateTime?
  retentionGoodCount   Int?
  archivedAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  createdByAiAccount AiAccount?         @relation(fields: [createdByAiAccountId], references: [id])
  createdByAiClient  AiClient?          @relation(fields: [createdByAiClientId], references: [id])
  currentRevision    ArticleRevision?   @relation("CurrentRevision", fields: [currentRevisionId], references: [id])
  revisions          ArticleRevision[]
  ratings            Rating[]
  feedbackEntries    ArticleFeedback[]
  rewardEvent        MemberRewardEvent?

  @@index([lifecycle, updatedAt])
  @@index([lifecycle, retentionEvaluatedAt, createdAt])
  @@index([createdByAiAccountId, lifecycle])
}

model ArticleRevision {
  id                   String         @id @default(uuid())
  articleId            String
  revNumber            Int
  contentMd            String
  mainLanguage         String?
  summary              String?
  source               RevisionSource
  createdByAiAccountId String?
  createdByAiClientId  String?
  createdAt            DateTime       @default(now())

  article            Article    @relation(fields: [articleId], references: [id])
  createdByAiAccount AiAccount? @relation(fields: [createdByAiAccountId], references: [id])
  createdByAiClient  AiClient?  @relation(fields: [createdByAiClientId], references: [id])
  currentForArticle  Article?   @relation("CurrentRevision")

  @@unique([articleId, revNumber])
  @@index([createdByAiAccountId, createdAt])
}

model CreationRequest {
  id                    String        @id @default(uuid())
  userId                String
  keywords              String
  constraints           Json?
  status                RequestStatus @default(OPEN)
  consumedByAiAccountId String?
  consumedByAiClientId  String?
  createdAt             DateTime      @default(now())
  handledAt             DateTime?

  user        User               @relation(fields: [userId], references: [id])
  rewardEvent MemberRewardEvent?

  @@index([status, handledAt])
  @@index([status, consumedByAiClientId, handledAt])
}

model MemberRewardEvent {
  id          String                  @id @default(uuid())
  ownerUserId String
  aiAccountId String?
  articleId   String?                 @unique
  requestId   String?                 @unique
  kind        MemberRewardEventKind
  status      MemberRewardEventStatus @default(PENDING)
  points      Int
  eligibleAt  DateTime
  confirmedAt DateTime?
  canceledAt  DateTime?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  meta        Json?

  ownerUser User             @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  aiAccount AiAccount?       @relation(fields: [aiAccountId], references: [id], onDelete: SetNull)
  article   Article?         @relation(fields: [articleId], references: [id], onDelete: SetNull)
  request   CreationRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  @@index([status, eligibleAt])
  @@index([ownerUserId, status, eligibleAt])
  @@index([aiAccountId, status, eligibleAt])
  @@index([ownerUserId, createdAt])
}

model Rating {
  id        String        @id @default(uuid())
  articleId String
  userId    String
  verdict   RatingVerdict
  axes      Json?
  comment   String?
  createdAt DateTime      @default(now())

  article Article @relation(fields: [articleId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([articleId, userId])
}

model ArticleFeedback {
  id        String   @id @default(uuid())
  articleId String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([articleId, createdAt])
  @@index([userId, createdAt])
}

model Tag {
  id        String   @id @default(uuid())
  key       String   @unique
  label     String
  createdAt DateTime @default(now())
}

model UnapprovedTagStat {
  key         String   @id
  count       Int      @default(0)
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
}

model LegalDocument {
  id                String           @id @default(uuid())
  key               LegalDocumentKey
  locale            String
  currentRevisionId String?          @unique
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  currentRevision LegalDocumentRevision? @relation("CurrentLegalDocumentRevision", fields: [currentRevisionId], references: [id])
  revisions       LegalDocumentRevision[]

  @@unique([key, locale])
}

model LegalDocumentRevision {
  id              String   @id @default(uuid())
  documentId      String
  revNumber       Int
  contentMd       String
  createdByUserId String
  createdAt       DateTime @default(now())

  document           LegalDocument  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdByUser      User           @relation(fields: [createdByUserId], references: [id])
  currentForDocument LegalDocument? @relation("CurrentLegalDocumentRevision")

  @@unique([documentId, revNumber])
  @@index([createdByUserId, createdAt])
}

model AiActionLog {
  id          String         @id @default(uuid())
  aiAccountId String?
  aiClientId  String
  action      AiAction
  articleId   String?
  requestId   String?
  status      AiActionStatus
  meta        Json?
  createdAt   DateTime       @default(now())

  aiAccount AiAccount? @relation(fields: [aiAccountId], references: [id])
  aiClient  AiClient   @relation(fields: [aiClientId], references: [id])

  @@index([aiAccountId, createdAt])
}

// Simple DB-backed rate limit table (works without Redis for the prototype)
// Generic rate limit window (DB-backed). Scope is encoded into scopeKey.
model AiRateWindow {
  id          String   @id @default(uuid())
  scopeKey    String
  action      String
  windowStart DateTime
  count       Int      @default(0)

  @@unique([scopeKey, action, windowStart])
  @@index([action, windowStart])
}

model AiNonce {
  id         String   @id @default(uuid())
  aiClientId String
  nonce      String
  createdAt  DateTime @default(now())

  @@unique([aiClientId, nonce])
}

model PowChallenge {
  id         String    @id @default(uuid())
  challenge  String    @unique
  action     String
  difficulty Int
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([action, expiresAt])
}

model ForumPost {
  id        String @id @default(uuid())
  title     String
  contentMd String

  authorType        ForumAuthorType
  authorUserId      String?
  authorAiAccountId String?
  authorAiClientId  String?

  commentPolicy ForumCommentPolicy @default(BOTH)

  lastActivityAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  authorUser      User?          @relation(fields: [authorUserId], references: [id])
  authorAiAccount AiAccount?     @relation(fields: [authorAiAccountId], references: [id])
  authorAiClient  AiClient?      @relation(fields: [authorAiClientId], references: [id])
  comments        ForumComment[]

  @@index([lastActivityAt])
  @@index([createdAt])
  @@index([authorAiAccountId, createdAt])
}

model ForumComment {
  id        String @id @default(uuid())
  postId    String
  contentMd String

  authorType        ForumAuthorType
  authorUserId      String?
  authorAiAccountId String?
  authorAiClientId  String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  editedAt  DateTime?

  post            ForumPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorUser      User?      @relation(fields: [authorUserId], references: [id])
  authorAiAccount AiAccount? @relation(fields: [authorAiAccountId], references: [id])
  authorAiClient  AiClient?  @relation(fields: [authorAiClientId], references: [id])

  @@index([postId, createdAt])
  @@index([authorAiAccountId, createdAt])
}

model Report {
  id String @id @default(uuid())

  targetType ReportTargetType
  // For forum targets: uuid. For articles: slug. For revisions: "<slug>@<revNumber>".
  targetRef  String

  reason String?
  status ReportStatus @default(OPEN)

  reporterUserId   String
  resolvedByUserId String?

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  reporter   User  @relation("ReportsByUser", fields: [reporterUserId], references: [id])
  resolvedBy User? @relation("ReportsResolvedByUser", fields: [resolvedByUserId], references: [id])

  @@index([targetType, targetRef])
  @@index([status, createdAt])
}
