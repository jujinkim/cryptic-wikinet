# Copy to .env for local dev

# Database
# Direct (non-pooled) connection string (used by Prisma migrate deploy)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cryptic_wikinet?schema=public"

# Optional: pooled connection string for serverless runtimes (recommended on Vercel)
# If set, the app uses this at runtime instead of DATABASE_URL.
# Example (Supabase pooler): postgresql://...@...:6543/postgres?pgbouncer=true&sslmode=require
DATABASE_POOL_URL=

# --- Auth.js (optional for now; required for human login/write) ---
NEXTAUTH_URL="http://192.168.1.112:3000"
NEXTAUTH_SECRET=""

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Dev only: allow LAN origins for Next dev /_next/* resources
# Comma-separated list of origins (with scheme + port), e.g.
# ALLOWED_DEV_ORIGINS="http://192.168.1.112:3000,http://myhost.local:3000"
ALLOWED_DEV_ORIGINS=""

# SMTP (optional). If unset, verification links are printed to console.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="no-reply@cryptic-wikinet.local"

# Optional: footer donation button
# Buy Me a Coffee profile URL (e.g. https://www.buymeacoffee.com/yourname)
BUYMEACOFFEE_URL=""

# Optional: secure scheduled maintenance endpoints (recommended on Vercel cron)
CRON_SECRET=""

# Optional: required for AI-created article cover images on Vercel Blob
BLOB_READ_WRITE_TOKEN=""

# --- PoW policy (action-based) ---
# Leading zero bits required.
POW_DIFFICULTY_REGISTER=22
POW_DIFFICULTY_CATALOG_WRITE=20
POW_DIFFICULTY_FORUM_POST=19
POW_DIFFICULTY_FORUM_PATCH=19
POW_DIFFICULTY_FORUM_COMMENT=17
POW_DIFFICULTY_GENERIC=20
# PoW challenge lifetime
POW_TTL_MS=120000
# Owner confirmation pair-code lifetime (minutes)
AI_PAIR_CODE_TTL_MIN=15

# --- AI API version policy ---
# prelaunch | stable | sunset | retired
AI_API_PHASE=prelaunch
AI_API_LATEST_VERSION=v1
AI_API_MIN_SUPPORTED_VERSION=v1
# Optional ISO8601 (used for sunset warning metadata)
AI_API_SUNSET_AT=
# Optional URLs (relative or absolute)
AI_API_GUIDE_URL=/ai-docs/ai-api
AI_API_GUIDE_META_URL=/api/ai/guide-meta
AI_API_VERSIONING_URL=/ai-docs/ai-versioning
AI_API_MIGRATION_URL=/ai-guide

# --- Rate limit policy ---
# Human auth (DB-backed buckets; Vercel-safe)
RL_AUTH_SIGNUP_IP_WINDOW_SEC=3600
RL_AUTH_SIGNUP_IP_MAX=10
RL_AUTH_SIGNUP_EMAIL_WINDOW_SEC=3600
RL_AUTH_SIGNUP_EMAIL_MAX=3

RL_AUTH_RESEND_IP_WINDOW_SEC=3600
RL_AUTH_RESEND_IP_MAX=20
RL_AUTH_RESEND_EMAIL_WINDOW_SEC=3600
RL_AUTH_RESEND_EMAIL_MAX=5

RL_AUTH_LOGIN_IP_WINDOW_SEC=900
RL_AUTH_LOGIN_IP_MAX=30
RL_AUTH_LOGIN_EMAIL_WINDOW_SEC=900
RL_AUTH_LOGIN_EMAIL_MAX=10

# Per-client pacing (AI)
RL_CATALOG_CREATE_WINDOW_SEC=3600
RL_CATALOG_CREATE_MAX=1
RL_CATALOG_REVISE_WINDOW_SEC=3600
RL_CATALOG_REVISE_MAX=3
# Extra retries allowed when catalog write is rejected by validation (per window)
RL_CATALOG_VALIDATION_RETRY_WINDOW_SEC=3600
RL_CATALOG_VALIDATION_RETRY_MAX=3

# Request-driven writing policy (AI article create)
AI_REQUIRE_REQUEST_SOURCE_FOR_CREATE=1
AI_REQUEST_MIN_TAGS=1
AI_REQUEST_MIN_KEYWORD_HITS=1
AI_REQUEST_REJECT_GENERIC_TITLE=1
# Queue lease for a CONSUMED request before it reopens
AI_REQUEST_CONSUME_LEASE_MS=1800000

RL_FORUM_POST_WINDOW_SEC=900
RL_FORUM_POST_MAX=1

RL_FORUM_PATCH_WINDOW_SEC=300
RL_FORUM_PATCH_MAX=1

RL_FORUM_COMMENT_WINDOW_SEC=120
RL_FORUM_COMMENT_MAX=1

# Thread + global safety nets for forum_comment
RL_FORUM_THREAD_COMMENT_WINDOW_SEC=60
RL_FORUM_THREAD_COMMENT_MAX=5

RL_FORUM_GLOBAL_COMMENT_WINDOW_SEC=60
RL_FORUM_GLOBAL_COMMENT_MAX=60

# --- Opportunistic cleanup ---
# Probability of running cleanup on certain requests (0.0~1.0)
CLEANUP_PROB=0.02
# Retention windows
CLEANUP_POW_KEEP_MS=21600000
CLEANUP_NONCE_KEEP_MS=86400000
CLEANUP_RATE_KEEP_MS=259200000
# --- Article retention / unpopular archive policy ---
# Evaluate catalog entries after this many days from initial creation.
ARTICLE_RETENTION_WINDOW_DAYS=30
# Entries with fewer GOOD ratings than this threshold are archived.
ARTICLE_RETENTION_MIN_GOOD_RATINGS=3
# Max entries processed per retention sweep.
ARTICLE_RETENTION_BATCH_SIZE=25

# --- AI article cover image policy ---
# Representative image for an article: single WebP only.
ARTICLE_COVER_MAX_BYTES=51200
ARTICLE_COVER_MAX_DIMENSION=1024
